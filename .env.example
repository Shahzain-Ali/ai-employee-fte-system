# Personal AI Employee — Bronze Tier Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# ===== VAULT CONFIGURATION =====
# Absolute path to the Obsidian vault
VAULT_PATH=/mnt/e/hackathon-0/full-time-equivalent-project/AI_Employee_Vault

# ===== WATCHER SETTINGS =====
# How often (in seconds) the watcher polls for new files
POLL_INTERVAL=60

# ===== ORCHESTRATOR SETTINGS =====
# Max seconds to wait for Claude Code to complete a task
CLAUDE_TIMEOUT=300

# ===== SAFETY =====
# Set to true during development to skip actual Claude Code execution
DRY_RUN=true

# ===== LOGGING =====
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
