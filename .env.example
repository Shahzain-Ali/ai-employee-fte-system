# Personal AI Employee — Bronze Tier Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# ===== VAULT CONFIGURATION =====
# Absolute path to the Obsidian vault
VAULT_PATH=./AI_Employee_Vault

# ===== WATCHER SETTINGS =====
# How often (in seconds) the watcher polls for new files
POLL_INTERVAL=60

# ===== ORCHESTRATOR SETTINGS =====
# Max seconds to wait for Claude Code to complete a task
CLAUDE_TIMEOUT=300

# ===== SAFETY =====
# Set to true during development to skip actual Claude Code execution
DRY_RUN=true

# ===== LOGGING =====
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===== GOLD TIER: ODOO =====
ODOO_URL=http://localhost:8069
ODOO_DB=fte_gold
ODOO_USER=admin
ODOO_PASSWORD=changeme

# ===== GOLD TIER: FACEBOOK =====
FB_PAGE_ID=your_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token

# ===== GOLD TIER: INSTAGRAM =====
IG_USER_ID=your_instagram_user_id
IG_ACCESS_TOKEN=your_ig_access_token

# ===== GOLD TIER: META API =====
META_API_VERSION=v21.0

# ===== GOLD TIER: CEO BRIEFING =====
OWNER_EMAIL=your_email@example.com

# ===== GOLD TIER: RALPH WIGGUM =====
RALPH_WIGGUM_MAX_ITERATIONS=10
