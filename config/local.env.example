# Local Agent Environment Variables — Platinum Tier
# Copy to .env on Local (WSL): cp local.env.example ~/fte-project/.env

# === Everything Cloud has ===

# Anthropic API Key (OPTIONAL — only needed for claude-agent-sdk direct API calls)
# If using Claude Code CLI (claude --print), authentication is handled by `claude login`
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gmail API credentials path (on Local)
GMAIL_CREDENTIALS_PATH=~/.credentials/gmail.json

# Meta (Facebook + Instagram) Page Access Token
META_PAGE_ACCESS_TOKEN=your-meta-page-token
META_PAGE_ID=your-page-id
META_IG_USER_ID=your-ig-user-id

# Twitter/X API credentials
TWITTER_API_KEY=your-twitter-key
TWITTER_API_SECRET=your-twitter-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# LinkedIn credentials
LINKEDIN_ACCESS_TOKEN=your-linkedin-token

# Odoo (remote — on Cloud VM via HTTPS)
ODOO_URL=https://odoo.yourdomain.com
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=your-odoo-password

# Vault and sync
VAULT_PATH=~/vault
GITHUB_SSH_KEY=~/.ssh/id_ed25519

# Agent config
AGENT_CONFIG=~/fte-project/config/local-agent.yaml
POLL_INTERVAL=60
CLAUDE_TIMEOUT=300

# === Local-Only Sensitive Credentials ===

# WhatsApp session (Playwright browser session — NEVER on Cloud)
WHATSAPP_SESSION_PATH=~/.whatsapp-session/

# Banking credentials (NEVER on Cloud)
BANKING_CREDENTIALS=~/.credentials/banking.json

# Personal API tokens (NEVER on Cloud)
PERSONAL_API_TOKENS=~/.credentials/personal_tokens.json
